import requests
import datetime
import json
from dotenv import load_dotenv
import os

# 加载 .env 文件中的环境变量
load_dotenv()

# 从环境变量中获取 API 密钥
API_KEY = os.getenv("API_KEY")

# Deepseek API 设置
DEEPSEEK_API_URL = "https://api.deepseek.com/v1/ai-news"  # 请替换为实际的 Deepseek API 地址

# 获取当天日期
today = datetime.datetime.today().strftime('%Y-%m-%d')

# 请求 Deepseek API 获取当天的 AI 新闻
def fetch_ai_news():
    params = {
        'date': today,
        'api_key': API_KEY  # 使用从 .env 文件加载的 API 密钥
    }
    
    try:
        response = requests.get(DEEPSEEK_API_URL, params=params)
        response.raise_for_status()  # 如果请求失败，会抛出异常
        
        # 假设返回的数据格式包含 'news' 键
        news_data = response.json()

        # 检查是否包含新闻数据
        if 'news' not in news_data:
            print("没有找到相关新闻数据")
            return []

        # 格式化新闻数据
        news_list = []
        for item in news_data['news']:
            news_item = {
                'title': item.get('title', '无标题'),
                'source': item.get('source', '未知来源'),
                'date': item.get('date', '未知时间'),
                'description': item.get('description', '无简要描述'),
            }
            news_list.append(news_item)

        return news_list
    except requests.exceptions.RequestException as e:
        print(f"请求错误: {e}")
        return []

# 格式化输出日报
def print_news_to_console(news_list):
    if not news_list:
        print("没有获取到最新的 AI 新闻")
        return

    print(f"AI 新闻日报 ({today}):\n")
    for idx, news in enumerate(news_list, start=1):
        print(f"{idx}. {news['title']}")
        print(f"   来源: {news['source']}")
        print(f"   时间: {news['date']}")
        print(f"   描述: {news['description']}\n")

# 保存新闻到文件
def save_news_to_file(news_list):
    if not news_list:
        print("没有获取到最新的 AI 新闻，无法保存文件")
        return

    # 保存为文件
    file_name = f"AI_News_{today}.txt"
    with open(file_name, 'w', encoding='utf-8') as file:
        file.write(f"AI 新闻日报 ({today}):\n\n")
        for idx, news in enumerate(news_list, start=1):
            file.write(f"{idx}. {news['title']}\n")
            file.write(f"   来源: {news['source']}\n")
            file.write(f"   时间: {news['date']}\n")
            file.write(f"   描述: {news['description']}\n\n")
    print(f"新闻已保存到 {file_name}")

# 主函数
def main():
    news_list = fetch_ai_news()
    print_news_to_console(news_list)  # 打印到控制台
    save_news_to_file(news_list)     # 保存为文件

if __name__ == "__main__":
    main()


